# MochiKit environment configuration
# Copy to .env and fill in your credentials.

# GLM (Zhipu) Anthropic-compatible endpoint for LLM calls
BASE_URL=https://open.bigmodel.cn/api/anthropic
API_KEY=your-api-key-here
MODEL=glm-4.7

# Optional: GLM web tool credentials (same key as API_KEY by default)
MOCHIKIT_WEB_API_KEY=your-api-key-here

# Set to 1 to run real-LLM integration tests
MOCHIKIT_RUN_INTEGRATION=0
