# MochiKit environment configuration
# Copy to .env and fill in your credentials.

# =============================================================================
# Default provider (backward compatible — no prefix)
# loadConfig() returns this provider.
# =============================================================================
BASE_URL=https://open.bigmodel.cn/api/anthropic
API_KEY=your-api-key-here
MODEL=glm-4.7

# Optional: Web tool credentials (falls back to API_KEY when not set)
MOCHIKIT_WEB_API_KEY=your-api-key-here

# Set to 1 to run real-LLM integration tests
MOCHIKIT_RUN_INTEGRATION=0

# =============================================================================
# Named providers — prefix convention: {NAME}_API_KEY, {NAME}_BASE_URL, {NAME}_MODEL
# Use with: loadConfig('deepseek') or loadConfig('openai')
# The prefix must be UPPERCASE — it is auto-discovered from process.env.
# =============================================================================

# DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# MCP Server configuration — prefix convention: MCP__<SERVER>__<FIELD>
#
# Declare MCP servers in .env to avoid hardcoding transport details in code.
# Use with: const mcp = createMCPPlugin(loadMCPConfigFromEnv())
#
# Supported transports: stdio (local subprocess), streamable-http (remote)
# Supported fields: TRANSPORT, COMMAND, ARGS, URL, HEADERS, PERMISSION
#
# PERMISSION: "auto-allow" (default — trust this server's tools)
#             "manual" (go through agent's permission pipeline)
# =============================================================================

# Local filesystem MCP server via stdio
# MCP__FILESYSTEM__TRANSPORT=stdio
# MCP__FILESYSTEM__COMMAND=npx
# MCP__FILESYSTEM__ARGS=-y @modelcontextprotocol/server-filesystem /tmp
# MCP__FILESYSTEM__PERMISSION=auto-allow

# Remote MCP server via streamable HTTP
# MCP__GITHUB__TRANSPORT=streamable-http
# MCP__GITHUB__URL=http://localhost:3000/mcp
# MCP__GITHUB__HEADERS=Authorization: Bearer sk-xxx
# MCP__GITHUB__PERMISSION=manual
